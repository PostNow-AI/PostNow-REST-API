# Environment variables for PostNow AI application

# Database Configuration
DB_NAME=
DB_USER=
DB_USER_PASSWORD=
DB_HOST=
DB_PORT=
# Gemini API Key
GEMINI_API_KEY=
# OAuth2 Configuration
GOOGLE_OAUTH2_CLIENT_ID=
GOOGLE_OAUTH2_CLIENT_SECRET=
FRONTEND_URL=
BACKEND_BASE_URL=
# Stripe Configuration
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Email Configuration
SENDER_NAME=
SENDER_EMAIL=
MJ_APIKEY_PUBLIC=
MJ_APIKEY_PRIVATE=
USE_MAILJET_EMAIL=
# Application Settings
CRON_SECRET=
# Search Services
SERPER_API_KEY=
# Optional: Jina Reader API key for higher rate limits (works without key too)
JINA_API_KEY=
# Async processing settings
MAX_CONCURRENT_USERS=
CONTENT_GENERATION_TIMEOUT=
ADMIN_EMAILS=
# AWS S3 Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=
AWS_S3_CHAT_HISTORY_BUCKET=
AWS_S3_IMAGE_BUCKET=
# Meta/Instagram OAuth Configuration
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:5173/auth/instagram/callback
# Set to 'true' to enable mock mode for testing without real Meta credentials
INSTAGRAM_MOCK_MODE=false